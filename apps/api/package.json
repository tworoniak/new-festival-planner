{
  "name": "api",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=.env src/db/seed.ts"
  },
  "dependencies": {
    "@festival-planner/shared": "workspace:*",
    "@hono/node-server": "^1.19.11",
    "@neondatabase/serverless": "^0.9.5",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.9",
    "shared@workspace:*": "link: @festival-planner/shared@workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
